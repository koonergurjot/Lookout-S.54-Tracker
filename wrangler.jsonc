{
  // Cloudflare Workers static-assets deploy for this local-first app.
  // No server/Worker code — only the static files in ./public are served.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lookoutbumpingtracker",
  "compatibility_date": "2026-06-26",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
